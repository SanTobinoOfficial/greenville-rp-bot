# ==========================================
# GREENVILLE RP BOT — Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij dane
# ==========================================

# --- Discord ---
DISCORD_TOKEN=              # Token bota z Discord Developer Portal
DISCORD_CLIENT_ID=          # Application ID
DISCORD_CLIENT_SECRET=      # OAuth2 Client Secret
DISCORD_GUILD_ID=           # ID serwera Discord
DISCORD_OWNER_ID=           # ID właściciela serwera (Discord User ID) — pełny dostęp do panelu

# --- Roblox ---
ROBLOX_GROUP_ID=

# --- Baza danych (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:5432/greenville_rp

# --- Dashboard (NextAuth) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://twojadomena.railway.app

# --- Komunikacja Bot <-> Dashboard ---
BOT_API_KEY=
BOT_API_URL=http://localhost:3001

# --- Radio (YouTube URL do RMF MAXX) ---
RADIO_URL=https://www.youtube.com/watch?v=9WIfFbHmhkI

# --- Środowisko ---
NODE_ENV=production
