// Schemat bazy danych Greenville RP
// Prisma ORM + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== UŻYTKOWNICY ====================

model User {
  id              String    @id @default(cuid())
  discordId       String    @unique
  discordUsername String
  robloxId        String?   @unique
  robloxUsername  String?
  phoneNumber     String?   @unique
  quizScore       Int?
  quizAttempts    Int       @default(0)
  quizLastAttempt DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  character      Character?
  vehicles       Vehicle[]
  licenses       License[]
  casesAsTarget  Case[]          @relation("TargetUser")
  casesAsMod     Case[]          @relation("ModeratorUser")
  applications   Application[]
  tickets        Ticket[]
  smsSent        SMS[]           @relation("Sender")
  smsReceived    SMS[]           @relation("Receiver")
  finesReceived  Fine[]          @relation("TargetFine")
  finesIssued    Fine[]          @relation("IssuedFine")
  sessionSignups SessionSignup[]
  quizTokens     QuizToken[]
  notes             Note[]             @relation("NoteTarget")
  notesAuthored     Note[]             @relation("NoteAuthor")
  dutyLogs          DutyLog[]
  arrests           Arrest[]           @relation("ArrestTarget")
  arrestsMade       Arrest[]           @relation("ArrestOfficer")
  news              News[]
  jobApplications   JobApplication[]
  proximityMessages ProximityMessage[]

  // ── Praca RP ─────────────────────────────────────────────────
  currentJob      String?
  jobCategory     String?
  jobAssignedAt   DateTime?
  jobCooldownEnd  DateTime?
}

// ==================== POSTAĆ (DOWÓD OSOBISTY) ====================

model Character {
  id         String   @id @default(cuid())
  userId     String   @unique
  firstName  String
  lastName   String
  birthDate  DateTime
  gender     String
  eyeColor   String?
  hairColor  String?
  photoUrl   String?
  peselRp    String   @unique
  documentId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== POJAZDY ====================

model Vehicle {
  id        String   @id @default(cuid())
  userId    String
  marka     String
  model     String
  rok       Int
  kolor     String
  tablica   String   @unique
  opis      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== PRAWO JAZDY ====================

model License {
  id              String        @id @default(cuid())
  userId          String
  kategoria       String
  status          LicenseStatus @default(ACTIVE)
  suspendedAt     DateTime?
  suspendedUntil  DateTime?
  suspendedReason String?
  issuedAt        DateTime      @default(now())
  examinatorId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kategoria])
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

// ==================== MANDATY RP ====================

model Fine {
  id        String   @id @default(cuid())
  targetId  String
  issuerId  String
  type      FineType
  amount    Int?
  reason    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  target User @relation("TargetFine", fields: [targetId], references: [id], onDelete: Cascade)
  issuer User @relation("IssuedFine", fields: [issuerId], references: [id], onDelete: Cascade)
}

enum FineType {
  MANDAT
  GRZYWNA
  ARESZT
}

// ==================== CASES MODERACYJNE ====================

model Case {
  id          String     @id @default(cuid())
  caseNumber  Int        @unique @default(autoincrement())
  type        CaseType
  targetId    String
  moderatorId String
  reason      String
  duration    Int?
  expiresAt   DateTime?
  status      CaseStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())

  target    User @relation("TargetUser", fields: [targetId], references: [id], onDelete: Cascade)
  moderator User @relation("ModeratorUser", fields: [moderatorId], references: [id], onDelete: Cascade)
}

enum CaseType {
  WARN
  BAN
  KICK
  MUTE
  UNBAN
  UNMUTE
}

enum CaseStatus {
  ACTIVE
  EXPIRED
  REMOVED
  APPEALED
}

// ==================== PODANIA ====================

model Application {
  id         String            @id @default(cuid())
  userId     String
  type       ApplicationType
  position   String
  answers    Json
  status     ApplicationStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime          @default(now())
  reviewedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ApplicationType {
  SERVICE
  JOB_PUBLIC
  JOB_PRIVATE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  INCOMPLETE
}

// ==================== TICKETY ====================

model Ticket {
  id           String       @id @default(cuid())
  ticketNumber Int          @unique @default(autoincrement())
  userId       String
  channelId    String       @unique
  category     String
  status       TicketStatus @default(OPEN)
  agentId      String?
  transcript   String?
  createdAt    DateTime     @default(now())
  closedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TicketStatus {
  OPEN
  CLAIMED
  CLOSED
}

// ==================== TELEFON RP ====================

model SMS {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       SMSType  @default(MESSAGE)
  createdAt  DateTime @default(now())

  sender   User @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

enum SMSType {
  MESSAGE
  CALL
}

// ==================== SESJE RP ====================

model Session {
  id          String        @id @default(cuid())
  hostId      String
  date        DateTime
  maxPlayers  Int
  description String?
  status      SessionStatus @default(UPCOMING)
  peacetime   Int           @default(0)
  messageId   String?
  channelId   String?
  createdAt   DateTime      @default(now())
  startedAt   DateTime?
  endedAt     DateTime?

  signups SessionSignup[]
}

enum SessionStatus {
  UPCOMING
  ONGOING
  ENDED
  CANCELLED
}

model SessionSignup {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

// ==================== QUIZ ====================

model QuizQuestion {
  id       String   @id @default(cuid())
  question String
  type     String   @default("CLOSED")  // "CLOSED" = wybór spośród opcji, "OPEN" = odpowiedź tekstowa
  answers  String[]                     // dla CLOSED: opcje A/B/C/D; dla OPEN: pusta tablica
  correct  Int      @default(0)         // dla CLOSED: indeks poprawnej odpowiedzi; dla OPEN: -1
  keywords String[] @default([])        // dla OPEN: słowa kluczowe punktujące odpowiedź
  tip      String   @default("")        // wyjaśnienie po odpowiedzi
  active   Boolean  @default(true)
  order    Int      @default(0)
}

model QuizToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApplicationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  position  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ==================== USTAWIENIA GLOBALNE ====================

model Settings {
  id                    String @id @default("global")

  // ── Pojazdy ──────────────────────────────────────────────────
  maxVehiclesBase       Int    @default(5)
  maxVehiclesSupporter  Int    @default(9)
  maxVehiclesBooster    Int    @default(10)

  // ── Quiz / Weryfikacja ────────────────────────────────────────
  quizPassScore         Int    @default(8)
  quizTotalQuestions    Int    @default(10)
  quizCooldownHours     Int    @default(24)
  robloxGroupId         String @default("")

  // ── RP Zasady ─────────────────────────────────────────────────
  frpSpeedLimit         Int    @default(131)
  maxMandaty            Int    @default(10)
  maxGrzywny            Int    @default(5)
  maxAreszty            Int    @default(5)
  licenseSuspensionDays Int    @default(30)

  // ── Ostrzeżenia auto-kary ─────────────────────────────────────
  warnAutoMuteCount     Int    @default(3)
  warnAutoBanCount      Int    @default(5)

  // ── Radio / CAD ───────────────────────────────────────────────
  radioUrl              String @default("https://www.youtube.com/watch?v=9WIfFbHmhkI")

  // ── Kanały Discord ────────────────────────────────────────────
  auditLogChannelId     String @default("")
  welcomeChannelId      String @default("")
  regulaminChannelId    String @default("")
  ogloszeniaChanelId    String @default("")
  zacznijTutajChannelId String @default("")
  ogolneChatChannelId   String @default("")

  // ── Tickety ───────────────────────────────────────────────────
  ticketEmbedChannelId  String @default("")
  ticketLogsChannelId   String @default("")
  ticketCategoryId      String @default("")
  ticketAdminRoleId     String @default("")
  ticketPingRoleId      String @default("")

  // ── Role Discord ──────────────────────────────────────────────
  roleOwner             String @default("")
  roleCoOwner           String @default("")
  roleAdmin             String @default("")
  roleMod               String @default("")
  roleHelper            String @default("")
  roleHR                String @default("")
  roleHost              String @default("")
  rolePolicja           String @default("")
  roleEMS               String @default("")
  roleStraz             String @default("")
  roleDOT               String @default("")
  roleMieszkaniec       String @default("1487555467302539368")
  roleNitroBooster      String @default("")
  roleWspierajacy       String @default("")

  // ── Embedy ────────────────────────────────────────────────────
  regulaminText         String @default("")
  regulaminMessageId    String @default("")
  embedColor            String @default("#5865F2")

  // ── Inne ──────────────────────────────────────────────────────
  setupCompleted        Boolean @default(false)
  guildId               String @default("")
  serverDescription     String @default("")
  maintenanceMode       Boolean @default(false)
  maintenanceMessage    String @default("Przerwa techniczna. Wrócimy wkrótce!")
}

// ==================== PODANIA O PRACĘ ====================

model JobApplication {
  id               String            @id @default(cuid())
  userId           String
  jobName          String
  jobCategory      String
  jobType          String            @default("PUBLIC")
  answers          Json
  status           ApplicationStatus @default(PENDING)
  reviewedBy       String?
  reviewNote       String?
  appliedAt        DateTime          @default(now())
  cooldownEnd      DateTime?
  reviewedAt       DateTime?
  discordMessageId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== NOTATKI MODERACYJNE ====================

model Note {
  id        String   @id @default(cuid())
  targetId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  target User @relation("NoteTarget", fields: [targetId], references: [id], onDelete: Cascade)
  author User @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

// ==================== LOGI DUTY SŁUŻB ====================

model DutyLog {
  id        String   @id @default(cuid())
  userId    String
  service   String
  action    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== ZATRZYMANIA ====================

model Arrest {
  id          String    @id @default(cuid())
  targetId    String
  officerId   String
  reason      String
  active      Boolean   @default(true)
  releasedAt  DateTime?
  releasedBy  String?
  createdAt   DateTime  @default(now())

  target  User @relation("ArrestTarget",  fields: [targetId],  references: [id], onDelete: Cascade)
  officer User @relation("ArrestOfficer", fields: [officerId], references: [id], onDelete: Cascade)
}

// ==================== NEWSY / OGŁOSZENIA ====================

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  imageUrl    String?
  category    String   @default("Ogłoszenie")
  authorId    String
  published   Boolean  @default(true)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

// ==================== PROXIMITY CHAT ====================

model ProximityMessage {
  id         String   @id @default(cuid())
  locationId String
  userId     String
  username   String
  content    String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== CAD SYSTEM ====================

model CadCall {
  id           String    @id @default(cuid())
  number       Int       @unique @default(autoincrement())
  nature       String
  location     String
  description  String?
  priority     String    @default("MEDIUM")   // LOW/MEDIUM/HIGH/CRITICAL
  status       String    @default("PENDING")  // PENDING/ACTIVE/CLOSED
  dispatchedTo String[]  @default([])
  reportedBy   String?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CadWarrant {
  id              String   @id @default(cuid())
  targetDiscordId String?
  targetName      String
  robloxName      String?
  reason          String
  issuedBy        String
  issuedByName    String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model CadUnit {
  id          String   @id @default(cuid())
  discordId   String   @unique
  callsign    String
  name        String
  service     String
  cadRole     String   @default("CYWIL")
  status      String   @default("AVAILABLE")
  onDutySince DateTime @default(now())
  lastSeen    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== LOGI BOTA ====================

model BotLog {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  guildId   String?
  message   String
  data      Json?
  createdAt DateTime @default(now())
}
